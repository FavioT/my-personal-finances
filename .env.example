# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-hex-string

# PIN de 4 dígitos para acceder a la app
APP_PIN=1234
